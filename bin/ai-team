#!/bin/bash
# ╔════════════════════════════════════════════════╗
# ║  ai-team — choose your fighter (sparkle ed.)  ║
# ╚════════════════════════════════════════════════╝
set -e
source "$HOME/dev-system/bin/_lib.sh"

TED_SESSION="AI-team-coach-TED"
BEARD_SESSION="AI-team-coach-BEARD"

# Pick an available coach session, or join the current one if already inside one
_current_session=$(tmux display-message -p '#S' 2>/dev/null || echo "")
if [ "$_current_session" = "$TED_SESSION" ] || [ "$_current_session" = "$BEARD_SESSION" ]; then
  : # already inside a coach session, proceed
elif ! tmux has-session -t "$TED_SESSION" 2>/dev/null; then
  printf "🎽  Starting TED — AI-team coach\n"
  tmux new-session -d -s "$TED_SESSION" "$0" "$@"
  tmux switch-client -t "$TED_SESSION"
  exit 0
elif ! tmux has-session -t "$BEARD_SESSION" 2>/dev/null; then
  printf "🧔  TED is busy — starting BEARD\n"
  tmux new-session -d -s "$BEARD_SESSION" "$0" "$@"
  tmux switch-client -t "$BEARD_SESSION"
  exit 0
else
  printf "❌  Both TED and BEARD are busy. Finish a flow first.\n"
  printf "    goto ted  |  goto beard\n"
  exit 1
fi

# Determine which coach we are for logging
COACH_SESSION=$(tmux display-message -p '#S' 2>/dev/null || echo "$TED_SESSION")
case "$COACH_SESSION" in
  *BEARD*) COACH_NAME="BEARD"; COACH_ICON="🧔" ;;
  *)       COACH_NAME="TED";   COACH_ICON="🎽" ;;
esac

# --- Gentle error if deps missing, but degrade gracefully ---
LOLCAT=""
BOXES=""
TOILET=""
command -v lolcat >/dev/null 2>&1 && LOLCAT=1
command -v boxes  >/dev/null 2>&1 && BOXES=1
command -v toilet >/dev/null 2>&1 && TOILET=1

# --- Random Hercule Poirot quote ---
random_quote() {
  local quotes=(
    '"The little grey cells, mon ami."'
    '"Order and method. Without them, nothing."'
    '"One does not need to bend the truth. The truth, it bends all by itself."'
    '"I do not run. I proceed with order and method."'
    '"It is the brain, the little grey cells, on which one must rely."'
    '"The impossible could not have happened, therefore the impossible must be possible in spite of appearances."'
    '"Tout de suite! Everything at once — it is not the Poirot way."'
    '"If the facts are hidden, one must employ the psychology."'
    '"Do not let the tongue outrun the brain."'
    '"Rest assured — Hercule Poirot will discover the truth."'
  )
  local idx=$((RANDOM % ${#quotes[@]}))
  printf '  🎩  %s\n\n' "${quotes[$idx]}"
}

# --- Banner ---
banner() {
  if [ -n "$TOILET" ]; then
    toilet -f smblock --gay "AI TEAM"
  else
    printf '\033[1;35m  ⚔️  AI TEAM — CHOOSE YOUR FIGHTER  ⚔️\033[0m\n\n'
  fi
}

# --- Clear screen, show header ---
clear
banner

if [ -n "$LOLCAT" ]; then
  random_quote | lolcat -f 2>/dev/null || random_quote
else
  random_quote
fi

# --- Menu items ---
items=(
  '🗺️  Full Recon       Watson → Nikke → Pat       W→N→P chain, full investigation'
  '🔍  Investigation    Nikke → Pat                bug analysis + fix'
  '🔨  Pat Solo         Claude implementor         straight to the code'
  '⚔️  Duel             Pat vs Mat                 compare Claude vs Gemini'
  '🔧  Mat Solo         Gemini implementor         Flash-powered fixes'
  '🗺️  Watson Solo      Map the territory          codebase context only'
)

# --- fzf selection ---
choice=$(
  printf '%s\n' "${items[@]}" \
  | fzf \
    --height=55% \
    --layout=reverse \
    --border=double \
    --border-label=' CHOOSE YOUR FIGHTER ' \
    --prompt='▶ ' \
    --pointer='➤ ' \
    --marker='✓ ' \
    --color='fg:#cdd6f4,bg:#1e1e2e,hl:#f5c2e7,fg+:#cdd6f4,bg+:#313244,hl+:#f5c2e7,pointer:#cba6f7,border:#cba6f7,prompt:#a6e3a1,marker:#f38ba8,header:#89b4fa' \
    --header='  ═══ SELECT WITH ARROW KEYS, ENTER TO CONFIRM ═══' \
    --preview='echo' \
    --preview-window=hidden \
    --no-info \
    --cycle
)

[ -z "$choice" ] && { printf '\n👋  Until next time.\n'; exit 0; }

# --- Branch prompt ---
printf '\n'
if [ -n "$BOXES" ]; then
  printf '\033[1;36mBranch name:\033[0m ' | boxes -d parchment 2>/dev/null || \
    printf '\033[1;36mBranch name:\033[0m '
else
  printf '\033[1;36mBranch:\033[0m '
fi
read -r branch
[ -z "$branch" ] && { printf '❌  Branch required.\n'; exit 1; }

# --- Sparkle transition ---
printf '\n'
if [ -n "$TOILET" ]; then
  toilet -f term --gay "GO!" 2>/dev/null || printf '⚡ GO! ⚡\n'
else
  printf '⚡  Launching... ⚡\n'
fi
sleep 0.3

# --- TED logging helpers ---
ted_ts() { date '+%H:%M:%S'; }
ted_divider() {
  printf "\033[0;35m  ────────────────────────────────────────\033[0m\n"
}
ted_log() {
  local msg
  msg=$(printf "\n\033[1;35m╔═ \033[1;37m%s\033[1;35m ══════════════════════════════════════╗\033[0m\n\033[1;35m║\033[0m  %s  \033[1;37m%s\033[0m\n\033[1;35m╚══════════════════════════════════════════╝\033[0m\n" "$COACH_NAME" "$COACH_ICON" "$*")
  if [ -n "$LOLCAT" ]; then printf '%s\n' "$msg" | lolcat -f 2>/dev/null; else printf '%s\n' "$msg"; fi
}
ted_start() {
  printf "\n  \033[1;32m⚡ %-10s\033[0m \033[0;37m%s\033[0m  \033[2;37m(%s)\033[0m\n" "$1" "$2" "$(ted_ts)"
  ted_divider
}
ted_done() {
  ted_divider
  printf "  \033[1;33m✅ %-10s\033[0m \033[0;37m%s\033[0m  \033[2;37m(%s)\033[0m\n" "$1" "$2" "$(ted_ts)"
}
ted_next() {
  local msg="  ✦  ✦  ✦  handoff → $1 ←  ✦  ✦  ✦"
  if [ -n "$LOLCAT" ]; then printf '\n%s\n\n' "$msg" | lolcat -f 2>/dev/null
  else printf "\n  \033[0;35m  ✦  ✦  ✦  handoff →\033[0m \033[1;36m%s\033[0m \033[0;35m←  ✦  ✦  ✦\033[0m\n\n" "$1"; fi
}
ted_complete() {
  printf '\n'
  if [ -n "$TOILET" ]; then
    toilet -f term --gay "DONE!" 2>/dev/null | { [ -n "$LOLCAT" ] && lolcat -f 2>/dev/null || cat; }
  else
    printf "\033[1;32m  🏁 FLOW COMPLETE\033[0m"
    [ -n "$LOLCAT" ] && printf '\n' | lolcat -f 2>/dev/null || printf '\n'
  fi
  printf "  \033[2;37m%s  ·  %s\033[0m\n\n" "$*" "$(ted_ts)"
}

# --- Launch ---
case "${choice:0:20}" in
  '🗺️  Full Recon'*)
    ted_log "Full Recon — Watson → Nikke → Pat  [$branch]"
    ted_start "Watson" "mapping codebase"
    watson "$branch"
    wait_for_agent "Watson"
    ted_done "Watson" "CONTEXT.md written"
    ted_next "Nikke"
    ted_start "Nikke" "investigating ticket"
    nikke -c
    wait_for_agent "Nikke"
    ted_done "Nikke" "INVESTIGATION.md written"
    ted_next "Pat"
    ted_start "Pat" "implementing fix"
    pat -c
    wait_for_agent "Pat"
    ted_done "Pat" "FIX-SUMMARY.md written — ready for review"
    ted_complete "Run: poirot"
    ;;
  '🔍  Investigation'*)
    ted_log "Investigation — Nikke → Pat  [$branch]"
    ted_start "Nikke" "investigating ticket (Watson inline)"
    nikke "$branch"
    wait_for_agent "Nikke"
    ted_done "Nikke" "INVESTIGATION.md written"
    ted_next "Pat"
    ted_start "Pat" "implementing fix"
    pat -c
    wait_for_agent "Pat"
    ted_done "Pat" "FIX-SUMMARY.md written — ready for review"
    ted_complete "Run: poirot"
    ;;
  '🔨  Pat Solo'*)
    ted_log "Pat Solo  [$branch]"
    ted_start "Pat" "implementing (Watson inline)"
    pat "$branch"
    wait_for_agent "Pat"
    ted_done "Pat" "done — ready for review"
    ted_complete "Run: poirot"
    ;;
  '⚔️  Duel'*)
    ted_log "Duel — Pat vs Mat  [$branch]"
    ted_start "Pat+Mat" "both implementing in parallel"
    duel "$branch"
    ted_complete "Run: poirot --compare when both finish"
    ;;
  '🔧  Mat Solo'*)
    ted_log "Mat Solo  [$branch]"
    ted_start "Mat" "implementing (Watson inline)"
    mat "$branch"
    wait_for_agent "Mat"
    ted_done "Mat" "done — ready for review"
    ted_complete "Run: poirot"
    ;;
  '🗺️  Watson Solo'*)
    ted_log "Watson Solo  [$branch]"
    ted_start "Watson" "mapping codebase"
    watson "$branch"
    wait_for_agent "Watson"
    ted_done "Watson" "CONTEXT.md written"
    ;;
  *) printf 'Unknown: %s\n' "$choice"; exit 1 ;;
esac