#!/bin/bash
# Usage: wt-clean all         # clean pat + mat + nikke
#        wt-clean pat         # clean pat only
#        wt-clean pat nikke   # clean specific roles
set -e

targets="${*:-all}"
[ "$targets" = "all" ] && targets="pat mat nikke"

cleaned=0

for role in $targets; do
  tracking="$HOME/.${role}_last_worktree"
  [ -f "$tracking" ] || { printf "⚠️  \033[1;33m%s\033[0m — no tracked worktree\n" "$role"; continue; }

  dir=$(cat "$tracking")
  [ -n "$dir" ] || continue

  if [ ! -d "$dir" ]; then
    printf "⚠️  \033[1;33m%s\033[0m worktree already gone: %s\n" "$role" "$dir"
    rm -f "$tracking"
    continue
  fi

  branch=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
  git worktree remove "$dir" --force
  [ -n "$branch" ] && git branch -d "$branch" 2>/dev/null || true
  rm -f "$tracking"

  printf "🗑️  \033[1;32mCleaned\033[0m %s (%s)\n" "$(basename "$dir")" "$branch"
  cleaned=$((cleaned + 1))
done

if [ "$cleaned" -eq 0 ]; then
  printf "Nothing cleaned.\n"
else
  printf "\n✅ Done. %d worktree(s) removed.\n" "$cleaned"
fi
