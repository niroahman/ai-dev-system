#!/bin/bash
# Usage:
#   pat fix/login-bug          # new worktree, editor, Claude
#   pat -c                      # continue in previous worktree
#   pat -c -w /path/to/wt       # continue in specific worktree
#   mat fix/login-bug           # gemini variant
#   mat -c                      # continue, gemini
set -e
source "$HOME/dev-system/bin/_lib.sh"

cont=0
wt_path=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c) cont=1; shift ;;
    -w) wt_path="$2"; shift 2 ;;
    *) break ;;
  esac
done

branch="${1:-}"

case "$(basename "$0")" in
  mat) agent="gemini" ;;
  *)   agent="claude" ;;
esac

resolve_role "$agent"
repo_root=$(git worktree list --porcelain | awk 'NR==1{print $2}')
repo_name=$(basename "$repo_root")

# --- Determine worktree ---
if [ "$cont" = "1" ]; then
  if [ -n "$wt_path" ]; then
    dir="$wt_path"
  else
    dir=$(find_continue_wt)
    if [ -z "$dir" ]; then
      echo "❌ No previous worktree found. Run watson or nikke first, or use -w <path>."
      exit 1
    fi
  fi

  if [ ! -d "$dir" ]; then
    echo "❌ Worktree gone: $dir"
    exit 1
  fi

  window_name="${ROLE_NAME}-$(basename "$dir")"
  printf "♻️  Reusing worktree: %s\n" "$(basename "$dir")"
else
  # New worktree
  if [ -z "$branch" ]; then
    echo "Usage: $(basename "$0") <branch>       new worktree"
    echo "       $(basename "$0") -c             continue previous"
    echo "       $(basename "$0") -c -w <path>   continue specific"
    exit 1
  fi

  # Hard cap: max 3 active worktrees
  active=$(git worktree list | wc -l)
  if [ "$((active - 1))" -ge 3 ]; then
    echo "You have $((active - 1)) active worktrees. Finish one first:"
    git worktree list
    exit 1
  fi

  dir="$repo_root/../wt-${repo_name}-${branch//\//-}"
  window_name="${ROLE_NAME}-${branch//\//-}"

  git worktree add "$dir" -b "$branch"

  build-context "$dir/.agent-context.md"
  setup_worktree "$dir" "$repo_root"
fi

# --- Watson maps the codebase first ---
run_watson_inline "$dir"

# --- Write task spec ---
# Using printf to avoid heredoc quoting issues with variables
{
  printf '%s\n\n' "$ROLE_PORTRAIT_MD"
  cat <<'TASKBODY'
# Context

Read in this order before starting:
1. .ai-team/context/TICKET.md — the ticket
2. .ai-team/context/*.png, *.jpg — screenshots
3. .ai-team/context/*.md — architecture docs
4. .ai-team/CONTEXT.md — Watson's codebase map (relevant files, code paths)
5. .ai-team/INVESTIGATION.md — Nikke's root cause analysis and recommended fix
6. AGENTS.md — repo conventions (follow these strictly)
7. .agent-context.md — personal skills

# Task

Implement the fix described in the ticket and investigation.

Rules:
- Follow AGENTS.md conventions for code style, testing, and patterns.
- Stay in scope — only change what is needed for the fix.
- Use the files Watson identified in CONTEXT.md as your starting point.
- Run tests after making changes.
- Do not leave debug code, TODOs, or commented-out blocks.

# Failure handling

If any command fails three times in a row (tests, linter, installs):
- STOP. Do not retry.
- Use AskUserQuestion to tell the human what failed and ask how to proceed.
- Wait for their answer before continuing.

Do not loop. Do not try workarounds. Blocked is a valid state.

# Review cycle

When you have finished the fix:
1. Run `poirot` from the shell. Read .ai-team/REVIEW.md.
2. Address every issue Poirot raised. Fix the code.
3. Run `poirot` once more — max 2 runs total. If issues persist, use AskUserQuestion to report what remains and ask how to proceed.
4. Write .ai-team/FIX-SUMMARY.md with:

## What changed
Every file modified and what was done.

## Why
Reasoning behind each decision. Flag anything uncertain.

## Anything skipped or deferred
Things you noticed but did not change.
TASKBODY
} > "$dir/.agent-task.md"

# --- Housekeeping ---
mkdir -p "$dir/.ai-team"
cp "$HOME/dev-system/portraits/$(echo "$ROLE_NAME" | tr '[:upper:]' '[:lower:]').png" "$dir/.ai-team/" 2>/dev/null || true
write_claude_settings "$dir"
track_worktree "$(basename "$0")" "$dir"

# --- Launch ---
printf "\n🔨 \033[1;32m%s\033[0m is taking on \033[1;36m%s\033[0m\n\n" "$ROLE_NAME" "$(basename "$dir")"

agent_cmd="$agent"
[ "$agent" = "gemini" ] && agent_cmd="gemini --model flash"

launch_tmux "$dir" "$window_name" "$agent_cmd \"Read .agent-task.md and start the task.\""
