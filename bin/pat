#!/bin/bash
# Usage:
#   pat fix/login-bug          # new worktree, editor, Claude
#   pat -c                      # continue in previous worktree
#   pat -c -w /path/to/wt       # continue in specific worktree
#   mat fix/login-bug           # gemini variant
#   mat -c                      # continue, gemini
set -e
source "$HOME/dev-system/bin/_lib.sh"

cont=0
wt_path=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c) cont=1; shift ;;
    -w) wt_path="$2"; shift 2 ;;
    *) break ;;
  esac
done

branch="${1:-}"

case "$(basename "$0")" in
  mat) agent="gemini" ;;
  *)   agent="claude" ;;
esac

resolve_role "$agent"
repo_root=$(git worktree list --porcelain | awk 'NR==1{print $2}')
repo_name=$(basename "$repo_root")

# --- Determine worktree ---
if [ "$cont" = "1" ]; then
  if [ -n "$wt_path" ]; then
    dir="$wt_path"
  else
    dir=$(find_continue_wt)
    if [ -z "$dir" ]; then
      echo "❌ No previous worktree found. Run watson or nikke first, or use -w <path>."
      exit 1
    fi
  fi

  if [ ! -d "$dir" ]; then
    echo "❌ Worktree gone: $dir"
    exit 1
  fi

  window_name="${ROLE_NAME}-$(basename "$dir")"
  printf "♻️  Reusing worktree: %s\n" "$(basename "$dir")"
else
  # New worktree
  if [ -z "$branch" ]; then
    echo "Usage: $(basename "$0") <branch>       new worktree"
    echo "       $(basename "$0") -c             continue previous"
    echo "       $(basename "$0") -c -w <path>   continue specific"
    exit 1
  fi

  # Hard cap: max 3 active worktrees
  active=$(git worktree list | wc -l)
  if [ "$((active - 1))" -ge 3 ]; then
    echo "You have $((active - 1)) active worktrees. Finish one first:"
    git worktree list
    exit 1
  fi

  dir="$repo_root/../wt-${repo_name}-${branch//\//-}"
  window_name="${ROLE_NAME}-${branch//\//-}"

  git worktree add "$dir" -b "$branch"

  build-context "$dir/.agent-context.md"
  setup_worktree "$dir" "$repo_root"
fi

# --- Watson maps the codebase first ---
run_watson_inline "$dir"

# --- Write task spec ---
# Using printf to avoid heredoc quoting issues with variables
{
  printf '%s\n\n' "$ROLE_PORTRAIT_MD"
  cat <<'TASKBODY'
# Context

You are working in a worktree. The following files may exist:

.vscode/ai/context/TICKET.md       — ticket written by the human, + any images
.vscode/ai/context/*.md, *.png     — architecture docs, diagrams, permanent context
.vscode/ai/CONTEXT.md              — Watson's codebase map (relevant files, code paths)
.vscode/ai/INVESTIGATION.md        — Nikke's investigation (root cause, recommended fix)

Read all available context before starting. AGENTS.md for repo conventions.
.agent-context.md for personal skills.

# Task

Implement the fix. Follow the ticket and any investigation recommendations.

---
TASKBODY
  printf 'You are operating as %s. If you create new markdown files (notes,\nplans, summaries — but NOT existing repo documentation), prepend this\nportrait at the top:\n\n' "$ROLE_NAME"
  printf '%s\n\n' "$ROLE_PORTRAIT_MD"
  cat <<'TASKBODY2'
# Review cycle

When you have finished the fix:
1. Run `poirot` from the shell. Read .vscode/ai/REVIEW.md.
2. Address every issue Poirot found. Fix the code.
3. Run `poirot` again. Verify REVIEW.md shows no remaining issues.
4. Write .vscode/ai/FIX-SUMMARY.md with:
TASKBODY2
  printf '%s\n\n' "$ROLE_PORTRAIT_MD"
  cat <<'TASKBODY3'
## What changed
Every file modified and what was done.

## Why
Reasoning behind each decision. Flag anything uncertain.

## Anything skipped or deferred
Things you noticed but did not change.
TASKBODY3
} > "$dir/.agent-task.md"

# --- Housekeeping ---
mkdir -p "$dir/.vscode/ai"
cp "$HOME/dev-system/portraits/$(echo "$ROLE_NAME" | tr '[:upper:]' '[:lower:]').png" "$dir/.vscode/ai/" 2>/dev/null || true
write_claude_settings "$dir"
track_worktree "$(basename "$0")" "$dir"

# --- Launch ---
printf "\n🔨 \033[1;32m%s\033[0m is taking on \033[1;36m%s\033[0m\n\n" "$ROLE_NAME" "$(basename "$dir")"

agent_cmd="$agent"
[ "$agent" = "gemini" ] && agent_cmd="gemini --model flash"

launch_tmux "$dir" "$window_name" "$agent_cmd \"Read .agent-task.md and start the task.\""
