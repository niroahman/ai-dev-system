#!/bin/bash
# Usage:
#   pat fix/login-bug "fix the login redirect"      # claude (Pat)
#   pat -n fix/login-bug "fix the login redirect"   # + pull in Nikke's last investigation
#   mat fix/login-bug "fix the login redirect"      # gemini (Mat)
#   pat fix/x "..." none                            # no agent, just shell
set -e
source "$HOME/dev-system/bin/_lib.sh"

use_nikke=0
if [ "$1" = "-n" ]; then
  use_nikke=1
  shift
fi

branch="$1"
task="$2"

case "$(basename "$0")" in
  mat) agent="${3:-gemini}" ;;
  *)   agent="${3:-claude}" ;;
esac

if [ -z "$branch" ]; then
  echo "Usage: $(basename "$0") [-n] <branch> [task] [none]"
  exit 1
fi
[ -z "$task" ] && [ "$use_nikke" = "1" ] && task="See INVESTIGATION.md for full context."
[ -z "$task" ] && { echo "Usage: $(basename "$0") [-n] <branch> [task] [none]"; exit 1; }

# Hard cap: max 3 active worktrees (friction is the feature)
active=$(git worktree list | wc -l)
if [ "$((active - 1))" -ge 3 ]; then
  echo "You have $((active - 1)) active worktrees. Finish one first:"
  git worktree list
  exit 1
fi

resolve_role "$agent"

repo_root=$(git worktree list --porcelain | awk 'NR==1{print $2}')
repo_name=$(basename "$repo_root")
dir="$repo_root/../wt-${repo_name}-${branch//\//-}"
window_name="${ROLE_NAME}-${branch//\//-}"

git worktree add "$dir" -b "$branch"

# Task spec, with portrait at top + role reminder at bottom
cat > "$dir/.agent-task.md" <<EOF
$ROLE_PORTRAIT_MD

# Task

$task

---

You are operating as $ROLE_NAME. If you create new markdown files (notes,
plans, summaries — but NOT existing repo documentation), prepend this
portrait at the top:

$ROLE_PORTRAIT_MD

If .vscode/ai/INVESTIGATION.md exists in this worktree, read it before
starting — it contains Nikke's analysis of the bug and recommended approach.

When you have finished the task, write .vscode/ai/FIX-SUMMARY.md with:

$ROLE_PORTRAIT_MD

## What changed
List every file modified and what was done.

## Why
Reasoning behind each decision. Flag anything you were uncertain about.

## Anything skipped or deferred
Things you noticed but did not change.
EOF

build-context "$dir/.agent-context.md"
mkdir -p "$dir/.vscode/ai"
cp "$HOME/dev-system/portraits/$(echo "$ROLE_NAME" | tr '[:upper:]' '[:lower:]').png" "$dir/.vscode/ai/" 2>/dev/null || true

if [ "$use_nikke" = "1" ]; then
  nikke_dir=$(cat "$HOME/.nikke_last_worktree" 2>/dev/null || echo "")
  if [ -n "$nikke_dir" ] && [ -f "$nikke_dir/.vscode/ai/INVESTIGATION.md" ]; then
    cp "$nikke_dir/.vscode/ai/INVESTIGATION.md" "$dir/.vscode/ai/INVESTIGATION.md"
    cp "$nikke_dir/.vscode/ai/nikke.png" "$dir/.vscode/ai/" 2>/dev/null || true
    printf "📋 Pulled Nikke's investigation from %s\n" "$(basename "$nikke_dir")"
  else
    printf "⚠️  No Nikke investigation found — run nikke first\n"
  fi
fi

mkdir -p "$dir/.claude"
cat > "$dir/.claude/settings.json" <<'EOF'
{
  "permissions": {
    "allow": ["Write", "Edit", "Read", "Bash(git *)", "Bash(npm *)", "Bash(pnpm *)", "Bash(yarn *)", "Bash(npx *)"]
  }
}
EOF

echo "$dir" > "$HOME/.$(basename "$0")_last_worktree"

printf "\n🔨 \033[1;32m%s\033[0m is taking on \033[1;36m%s\033[0m\n\n" "$ROLE_NAME" "$branch"

agent_cmd="$agent"
[ "$agent" = "gemini" ] && agent_cmd="gemini --model flash"

if [ -n "$TMUX" ]; then
  if [ "$agent" = "none" ]; then
    tmux new-session -d -s "$window_name" -c "$dir"
  else
    tmux new-session -d -s "$window_name" -c "$dir" $agent_cmd "Read .agent-task.md and start the task."
  fi
  printf "🪟  Session \033[1;33m%s\033[0m started — run \033[1mgoto %s\033[0m to visit\n" "$window_name" "$(echo "$ROLE_NAME" | tr '[:upper:]' '[:lower:]')"
else
  cd "$dir"
  [ "$agent" = "none" ] && exec $SHELL || exec $agent_cmd "Read .agent-task.md and start the task."
fi
