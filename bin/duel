#!/bin/bash
# Spin up Pat (claude) and Mat (gemini) on the same task.
# Usage:
#   duel fix/my-branch
set -e
source "$HOME/dev-system/bin/_lib.sh"

branch="$1"

if [ -z "$branch" ]; then
  echo "Usage: duel <branch>"
  exit 1
fi

printf "\n⚔️  \033[1;37mDuel started\033[0m — Pat vs Mat on \033[1;36m%s\033[0m\n\n" "$branch"

pat "${branch}-pat"
mat "${branch}-mat"
