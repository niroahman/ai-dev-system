#!/bin/bash
# Usage:
#   watson WEB-7373             # new worktree, editor, context mapping
#   watson -c                    # continue in previous worktree
#   watson -c -w /path/to/wt     # continue in specific worktree
#   watson --inline <dir>        # run sync in existing dir (no tmux)
#   watson --claude WEB-7373     # use Claude Haiku instead of Gemini Flash
set -e
source "$HOME/dev-system/bin/_lib.sh"

cont=0
wt_path=""
inline_dir=""
use_claude=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c) cont=1; shift ;;
    -w) wt_path="$2"; shift 2 ;;
    --inline) inline_dir="$2"; shift 2 ;;
    --claude) use_claude=1; shift ;;
    *) break ;;
  esac
done

branch="${1:-}"
resolve_named_role "Watson"

# --- Inline mode (called by nikke/pat/mat) ---
if [ -n "$inline_dir" ]; then
  printf "🗺️  \033[1;36mWatson\033[0m mapping the codebase...\n"

  {
    printf '%s\n\n' "$ROLE_PORTRAIT_MD"
    printf 'You are operating as %s — the context gatherer. You MAP THE TERRITORY.\n' "$ROLE_NAME"
    printf 'You do NOT diagnose bugs or fix code.\n\n'
    cat <<'WATSONINLINE'
# Context

Read .ai-team/context/TICKET.md for the ticket. Read any images there.
Your only job is to write .ai-team/CONTEXT.md. Be fast. Stop early.

Steps (strict order, strict caps):
1. Read the ticket. Extract 3-5 key terms (component names, function names, file hints).
2. Search for files matching those terms. List matches — do NOT read them all.
3. Read at most 5 files. Pick the most central ones only.
4. Run ONE git command across all relevant files: git log --oneline -15 -- <file1> <file2> ...
5. Skim test directory names for matches. Do not read test files.
6. STOP. Write CONTEXT.md now.

Write .ai-team/CONTEXT.md with:

## Relevant files
Each file with brief reason why relevant. List files you did not read too.

## Key code paths
Function/method names. File:line references where notable.

## Recent changes
From the single git log run above.

## Related tests
Test file paths only (no reading).

## Codebase patterns
1-3 lines max. Only what is obvious from files already read.

## Focus areas for deeper investigation
2-5 specific questions or areas worth digging into next.

Facts only. No diagnosis. No fixes. No speculation beyond what you observe.
Be terse — this is a map, not an essay. Target: done in 2-3 minutes.
WATSONINLINE
  } > "$inline_dir/.watson-prompt.md"

  mkdir -p "$inline_dir/.ai-team"
  if [ "$use_claude" = "1" ]; then
    (cd "$inline_dir" && claude --model claude-haiku-4-5-20251001 "Read .watson-prompt.md and follow it exactly.") || true
  else
    (cd "$inline_dir" && gemini --model flash -p "Read .watson-prompt.md and follow it exactly." -y 2>/dev/null) || true
  fi
  printf "✅  Watson done\n"
  exit 0
fi

# --- Standalone mode ---
repo_root=$(git worktree list --porcelain | awk 'NR==1{print $2}')
repo_name=$(basename "$repo_root")

if [ "$cont" = "1" ]; then
  if [ -n "$wt_path" ]; then
    dir="$wt_path"
  else
    dir=$(find_continue_wt)
    if [ -z "$dir" ]; then
      echo "❌ No previous worktree found. Use -w <path>."
      exit 1
    fi
  fi

  if [ ! -d "$dir" ]; then
    echo "❌ Worktree gone: $dir"
    exit 1
  fi

  window_name="${ROLE_NAME}-$(basename "$dir")"
  printf "♻️  Reusing worktree: %s\n" "$(basename "$dir")"
else
  if [ -z "$branch" ]; then
    echo "Usage: watson <branch>            new worktree"
    echo "       watson -c                  continue previous"
    echo "       watson -c -w <path>        continue specific"
    exit 1
  fi

  dir="$repo_root/../wt-${repo_name}-gather-${branch//\//-}"
  window_name="${ROLE_NAME}-gather-${branch//\//-}"

  git worktree add "$dir" -b "gather/$branch"

  build-context "$dir/.agent-context.md"
  setup_worktree "$dir" "$repo_root"
fi

# --- Write watson prompt ---
{
  printf '%s\n\n' "$ROLE_PORTRAIT_MD"
  printf 'You are operating as %s — the context gatherer. You MAP THE TERRITORY.\n' "$ROLE_NAME"
  printf 'You do NOT diagnose bugs or fix code.\n\n'
  cat <<'WATSONBODY'
# Context

Read .ai-team/context/TICKET.md for the ticket. Read any images there.
Your only job is to write .ai-team/CONTEXT.md. Be fast. Stop early.

Steps (strict order, strict caps):
1. Read the ticket. Extract 3-5 key terms (component names, function names, file hints).
2. Search for files matching those terms. List matches — do NOT read them all.
3. Read at most 5 files. Pick the most central ones only.
4. Run ONE git command across all relevant files: git log --oneline -15 -- <file1> <file2> ...
5. Skim test directory names for matches. Do not read test files.
6. STOP. Write CONTEXT.md now.

Write .ai-team/CONTEXT.md with:

## Relevant files
Each file with brief reason why relevant. List files you did not read too.

## Key code paths
Function/method names. File:line references where notable.

## Recent changes
From the single git log run above.

## Related tests
Test file paths only (no reading).

## Codebase patterns
1-3 lines max. Only what is obvious from files already read.

## Focus areas for deeper investigation
2-5 specific questions or areas worth digging into next.

Facts only. No diagnosis. No fixes. No speculation beyond what you observe.
Be terse — this is a map, not an essay. Target: done in 2-3 minutes.
WATSONBODY
} > "$dir/.watson-prompt.md"

# --- Housekeeping ---
mkdir -p "$dir/.ai-team"
cp "$HOME/dev-system/portraits/watson.png" "$dir/.ai-team/" 2>/dev/null || true
write_claude_settings "$dir"
track_worktree "watson" "$dir"

# --- Launch ---
printf "\n🗺️  \033[1;36mWatson\033[0m is mapping: \033[1;36m%s\033[0m\n\n" "$(basename "$dir")"

if [ "$use_claude" = "1" ]; then
  launch_tmux "$dir" "$window_name" "claude --model claude-haiku-4-5-20251001 \"Read .watson-prompt.md and follow it exactly.\""
else
  launch_tmux "$dir" "$window_name" "gemini --model flash \"Read .watson-prompt.md and follow it exactly.\""
fi
