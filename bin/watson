#!/bin/bash
# Usage:
#   watson WEB-7373             # new worktree, editor, context mapping (Claude Haiku)
#   watson -c                    # continue in previous worktree
#   watson -c -w /path/to/wt     # continue in specific worktree
#   watson --inline <dir>        # run sync in existing dir (no tmux)
#   watson --gemini WEB-7373     # use Gemini Flash instead of Claude Haiku
set -e
source "$HOME/dev-system/bin/_lib.sh"

cont=0
wt_path=""
inline_dir=""
use_gemini=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c) cont=1; shift ;;
    -w) wt_path="$2"; shift 2 ;;
    --inline) inline_dir="$2"; shift 2 ;;
    --gemini) use_gemini=1; shift ;;
    *) break ;;
  esac
done

branch="${1:-}"
resolve_named_role "Watson"

# --- Inline mode (called by nikke/pat/mat) ---
if [ -n "$inline_dir" ]; then
  mkdir -p "$inline_dir/.ai-team"

  # Write watson prompt
  {
    printf '%s\n\n' "$ROLE_PORTRAIT_MD"
    printf 'You are operating as %s — the context gatherer. You MAP THE TERRITORY.\n' "$ROLE_NAME"
    printf 'You do NOT diagnose bugs or fix code.\n\n'
    cat <<'WATSONINLINE'
# Context

Read .ai-team/context/TICKET.md for the ticket. Read any images there.
Your only job is to write .ai-team/WATSON_MAP.md. Be fast. Stop early.

STRICT ORDER — HARD CAPS — STOP EARLY:
1. Read ticket. Extract 2 key terms max. One grep/glob command only.
2. Search ONE directory: src/ if exists, else app/ if exists, else root. No recursive glob.
3. Read at most 3 files. If you find the relevant file in under 3, stop sooner.
4. Run ONE git log command only: git log --oneline -10.
5. Check package.json for test scripts (read file, no search). Skip config file hunting.
6. Write WATSON_MAP.md with what you have. 90-second hard target.

Write .ai-team/WATSON_MAP.md with:

## Relevant files
Each file with brief reason why relevant. List files you did not read too.

## Key code paths
Function/method names. File:line references where notable.

## Recent changes
From the single git log run above.

## Related tests
Test file paths only (no reading).

## Test commands
List each detected test framework and the exact command(s) to run. Include lint/typecheck if available. Format:
- jest: `npx jest`
- vitest: `npx vitest run`
- playwright: `npx playwright test`
- go test: `go test ./...`
- pytest: `pytest`
- lint: `npm run lint`
- typecheck: `npm run typecheck`

## Codebase patterns
1-3 lines max. Only what is obvious from files already read.

## Focus areas for deeper investigation
2-5 specific questions or areas worth digging into next.

Facts only. No diagnosis. No fixes. No speculation beyond what you observe.
Be terse — this is a map, not an essay. Target: done in 2-3 minutes.
Stay inside the worktree — no searches outside this directory.
WATSONINLINE
  } > "$inline_dir/.watson-prompt.md"

  if [ "$use_gemini" = "1" ]; then
    (cd "$inline_dir" && ${MODEL_WATSON_GEMINI:-gemini --model flash} -p "Read .watson-prompt.md and follow it exactly." -y) || true
  else
    _wmodel=${MODEL_WATSON:-}
    (cd "$inline_dir" && claude ${_wmodel:+--model "$_wmodel"} -p "Read .watson-prompt.md and follow it exactly." --permission-mode bypassPermissions) || true
  fi
  printf "✅  Watson done\n"
  exit 0
fi

# --- Standalone mode ---
repo_root=$(git worktree list --porcelain | awk 'NR==1{print $2}')
repo_name=$(basename "$repo_root")

if [ "$cont" = "1" ]; then
  if [ -n "$wt_path" ]; then
    dir="$wt_path"
  else
    dir=$(find_continue_wt)
    if [ -z "$dir" ]; then
      echo "❌ No previous worktree found. Use -w <path>."
      exit 1
    fi
  fi

  if [ ! -d "$dir" ]; then
    echo "❌ Worktree gone: $dir"
    exit 1
  fi

  window_name="${ROLE_NAME}-$(basename "$dir")"
  printf "♻️  Reusing worktree: %s\n" "$(basename "$dir")"
else
  if [ -z "$branch" ]; then
    echo "Usage: watson <branch>            new worktree"
    echo "       watson -c                  continue previous"
    echo "       watson -c -w <path>        continue specific"
    exit 1
  fi

  dir="$repo_root/../wt-${repo_name}-gather-${branch//\//-}"
  window_name="${ROLE_NAME}-gather-${branch//\//-}"

  git worktree add "$dir" -b "gather/$branch"

  build-context "$dir/.agent-context.md"
  setup_worktree "$dir" "$repo_root"
fi

# --- Write watson prompt ---
{
  printf '%s\n\n' "$ROLE_PORTRAIT_MD"
  printf 'You are operating as %s — the context gatherer. You MAP THE TERRITORY.\n' "$ROLE_NAME"
  printf 'You do NOT diagnose bugs or fix code.\n\n'
  cat <<'WATSONBODY'
# Context

Read .ai-team/context/TICKET.md for the ticket. Read any images there.
Your only job is to write .ai-team/WATSON_MAP.md. Be fast. Stop early.

STRICT ORDER — HARD CAPS — STOP EARLY:
1. Read ticket. Extract 2 key terms max. One grep/glob command only.
2. Search ONE directory: src/ if exists, else app/ if exists, else root. No recursive glob.
3. Read at most 3 files. If you find the relevant file in under 3, stop sooner.
4. Run ONE git log command only: git log --oneline -10.
5. Check package.json for test scripts (read file, no search). Skip config file hunting.
6. Write WATSON_MAP.md with what you have. 90-second hard target.

Write .ai-team/WATSON_MAP.md with:

## Relevant files
Each file with brief reason why relevant. List files you did not read too.

## Key code paths
Function/method names. File:line references where notable.

## Recent changes
From the single git log run above.

## Related tests
Test file paths only (no reading).

## Test commands
List each detected test framework and the exact command(s) to run. Include lint/typecheck if available. Format:
- jest: `npx jest`
- vitest: `npx vitest run`
- playwright: `npx playwright test`
- go test: `go test ./...`
- pytest: `pytest`
- lint: `npm run lint`
- typecheck: `npm run typecheck`

## Codebase patterns
1-3 lines max. Only what is obvious from files already read.

## Focus areas for deeper investigation
2-5 specific questions or areas worth digging into next.

Facts only. No diagnosis. No fixes. No speculation beyond what you observe.
Be terse — this is a map, not an essay. Target: done in 2-3 minutes.
Stay inside the worktree — no searches outside this directory.
WATSONBODY
} > "$dir/.watson-prompt.md"

# --- Housekeeping ---
mkdir -p "$dir/.ai-team"
cp "$HOME/dev-system/portraits/watson.png" "$dir/.ai-team/" 2>/dev/null || true
write_claude_settings "$dir"
track_worktree "watson" "$dir"

# --- Launch ---
printf "\n🗺️  \033[1;36mWatson\033[0m is mapping: \033[1;36m%s\033[0m\n\n" "$(basename "$dir")"

if [ "$use_gemini" = "1" ]; then
  launch_tmux "$dir" "$window_name" "${MODEL_WATSON_GEMINI:-gemini --model flash} \"Read .watson-prompt.md and follow it exactly.\""
else
  _wmodel=${MODEL_WATSON:-}
  if [ -n "$_wmodel" ]; then
    launch_tmux "$dir" "$window_name" "claude --model \"$_wmodel\" \"Read .watson-prompt.md and follow it exactly.\""
  else
    launch_tmux "$dir" "$window_name" "claude \"Read .watson-prompt.md and follow it exactly.\""
  fi
fi
