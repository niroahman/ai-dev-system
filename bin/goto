#!/bin/bash
# Usage: goto pat | goto mat | goto nikke
# cd to the role's last worktree in current shell, or switch tmux window.
set -e

role="${1:-}"
if [ -z "$role" ]; then
  echo "Usage: goto <pat|mat|nikke>"
  exit 1
fi

tracking="$HOME/.${role}_last_worktree"
if [ ! -f "$tracking" ]; then
  printf "❌ No tracked worktree for %s\n" "$role"
  exit 1
fi

dir=$(cat "$tracking")
if [ ! -d "$dir" ]; then
  printf "❌ Worktree gone: %s\n" "$dir"
  exit 1
fi

if [ -n "$TMUX" ]; then
  window=$(tmux list-windows -F "#{window_index} #{window_name}" 2>/dev/null \
    | grep -i "^[0-9]* $role" | awk '{print $1}' | head -1)
  if [ -n "$window" ]; then
    tmux select-window -t "$window"
  else
    printf "📂 No tmux window for %s — opening new window at %s\n" "$role" "$dir"
    tmux new-window -c "$dir"
  fi
else
  cd "$dir"
  printf "📂 Now in %s\n" "$dir"
  exec $SHELL
fi
