#!/bin/bash
# Usage: goto pat | goto mat | goto nikke | goto ted | goto ted wt
# Switch to role's tmux session, or cd to its worktree.
# goto ted wt / goto beard wt — open new window at the coach's active worktree.
set -e

TED_SESSION="AI-team-coach-TED"
BEARD_SESSION="AI-team-coach-BEARD"

role="${1:-}"
sub="${2:-}"
if [ -z "$role" ]; then
  echo "Usage: goto <pat|mat|nikke|ted|beard> [wt]"
  exit 1
fi

# Coaches
if [ "$role" = "ted" ] || [ "$role" = "beard" ]; then
  [ "$role" = "ted" ] && target="$TED_SESSION" || target="$BEARD_SESSION"

  # goto ted wt — jump to the worktree the coach is managing
  if [ "$sub" = "wt" ]; then
    wt=$(cat "$HOME/.${role}_wt" 2>/dev/null || echo "")
    if [ -z "$wt" ] || [ ! -d "$wt" ]; then
      printf "❌ No active worktree for %s\n" "$(echo "$role" | tr '[:lower:]' '[:upper:]')"
      exit 1
    fi
    wt=$(cd "$wt" && pwd)
    if [ -n "$TMUX" ]; then
      printf "📂 Opening worktree: %s\n" "$wt"
      tmux new-window -c "$wt"
    else
      cd "$wt"
      printf "📂 Now in %s\n" "$wt"
      exec $SHELL
    fi
    exit 0
  fi

  if [ -n "$TMUX" ]; then
    if tmux has-session -t "$target" 2>/dev/null; then
      tmux switch-client -t "$target"
    else
      printf "❌ %s is not running\n" "$(echo "$role" | tr '[:lower:]' '[:upper:]')"
      exit 1
    fi
  else
    tmux attach-session -t "$target" 2>/dev/null || printf "❌ %s is not running\n" "$(echo "$role" | tr '[:lower:]' '[:upper:]')"
  fi
  exit 0
fi

tracking="$HOME/.${role}_last_worktree"
if [ ! -f "$tracking" ]; then
  printf "❌ No tracked worktree for %s\n" "$role"
  exit 1
fi

dir=$(cat "$tracking")
if [ ! -d "$dir" ]; then
  printf "❌ Worktree gone: %s\n" "$dir"
  exit 1
fi

if [ -n "$TMUX" ]; then
  role_cap="$(echo "${role:0:1}" | tr '[:lower:]' '[:upper:]')${role:1}"
  session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null \
    | grep -i "^${role_cap}" | head -1)
  if [ -n "$session" ]; then
    tmux switch-client -t "$session"
  else
    printf "📂 No tmux session for %s — opening new window at %s\n" "$role" "$dir"
    tmux new-window -c "$dir"
  fi
else
  cd "$dir"
  printf "📂 Now in %s\n" "$dir"
  exec $SHELL
fi
