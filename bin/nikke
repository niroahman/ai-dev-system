#!/bin/bash
# Usage:
#   nikke login-bug             # new worktree, editor, Watson --inline, investigation
#   nikke -c                     # continue in previous worktree
#   nikke -c -w /path/to/wt      # continue in specific worktree
#   nikke --gemini login-bug     # use gemini for investigation
set -e
source "$HOME/dev-system/bin/_lib.sh"

cont=0
wt_path=""
agent="claude"
skip_watson=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c) cont=1; shift ;;
    -w) wt_path="$2"; shift 2 ;;
    --gemini) agent="gemini"; shift ;;
    --no-watson) skip_watson=1; shift ;;
    *) break ;;
  esac
done

branch="${1:-}"
resolve_named_role "Nikke"
repo_root=$(git worktree list --porcelain | awk 'NR==1{print $2}')
repo_name=$(basename "$repo_root")

# --- Determine worktree ---
if [ "$cont" = "1" ]; then
  if [ -n "$wt_path" ]; then
    dir="$wt_path"
  else
    dir=$(find_continue_wt)
    if [ -z "$dir" ]; then
      echo "❌ No previous worktree found. Run watson first, or use -w <path>."
      exit 1
    fi
  fi

  if [ ! -d "$dir" ]; then
    echo "❌ Worktree gone: $dir"
    exit 1
  fi

  window_name="${ROLE_NAME}-$(basename "$dir")"
  printf "♻️  Reusing worktree: %s\n" "$(basename "$dir")"
else
  if [ -z "$branch" ]; then
    echo "Usage: nikke <branch>             new worktree"
    echo "       nikke -c                   continue previous"
    echo "       nikke -c -w <path>         continue specific"
    exit 1
  fi

  dir="$repo_root/../wt-${repo_name}-investigate-${branch//\//-}"
  window_name="${ROLE_NAME}-investigate-${branch//\//-}"

  git worktree add "$dir" -b "investigate/$branch"

  build-context "$dir/.agent-context.md"
  setup_worktree "$dir" "$repo_root"
fi

# --- Watson runs inline first (unless caller already ran it) ---
[ "$skip_watson" = "0" ] && run_watson_inline "$dir"

# --- Write investigation prompt ---
{
  printf '%s\n\n' "$ROLE_PORTRAIT_MD"
  printf 'You are operating as %s — the investigator. You DO NOT FIX CODE.\n' "$ROLE_NAME"
  printf 'Your only job is to write .ai-team/INVESTIGATION.md in the worktree root.\n\n'
  cat <<'NIKKEBODY'
# Context

Read in this order before starting:
1. .ai-team/context/TICKET.md — the ticket
2. .ai-team/context/*.png, *.jpg — screenshots (often contain info the text omits)
3. .ai-team/context/*.md — architecture docs
4. .ai-team/WATSON_MAP.md — Watson's codebase map
5. AGENTS.md — repo conventions
6. .agent-context.md — personal skills

# Investigation

1. Read the ticket carefully. Note any ambiguity.
2. Look at any screenshots — they often contain info the text omits.
3. Reproduce the issue mentally by tracing through the code.
4. Form hypotheses about root cause. Check each one in the code.
5. If you need to run tests or add temporary logging to verify, do so —
   this is a throwaway worktree. If a command fails three times, stop trying it. Use AskUserQuestion
   to report what failed, then note it as unverified and move on.

Write .ai-team/INVESTIGATION.md with:

## Summary
One paragraph: what the bug is, where it lives, confidence level.

## Reproduction
Steps that should trigger it, verified or hypothetical (mark which).

## Root cause
File:line references. Be specific.

## Why other causes were ruled out
Brief, only for plausible-but-wrong hypotheses.

## Recommended fix
Approach, not code. If multiple valid options, list them with trade-offs.

## Estimated scope
Files touched, ~lines changed, risk level.

## Open questions
Anything you couldn't determine. Address these to the human.

Be terse. No filler. If the ticket is ambiguous or the bug isn't reproducible
from available info, say so explicitly — don't invent a story.
NIKKEBODY
} > "$dir/.investigate-prompt.md"

# --- Housekeeping ---
mkdir -p "$dir/.ai-team"
cp "$HOME/dev-system/portraits/nikke.png" "$dir/.ai-team/" 2>/dev/null || true
write_claude_settings "$dir"
track_worktree "nikke" "$dir"

# --- Launch ---
printf "\n🔍 \033[1;33mNikke\033[0m is on the case: \033[1;36m%s\033[0m\n\n" "$(basename "$dir")"

if [ "$agent" = "gemini" ]; then
  launch_tmux "$dir" "$window_name" "${MODEL_MAT:-gemini --model flash} \"Read .investigate-prompt.md and follow it exactly.\""
else
  _nikke_model="${MODEL_NIKKE:-claude}"
  [ "$_nikke_model" = "claude" ] \
    && launch_tmux "$dir" "$window_name" "claude \"Read .investigate-prompt.md and follow it exactly.\"" \
    || launch_tmux "$dir" "$window_name" "claude --model \"$_nikke_model\" \"Read .investigate-prompt.md and follow it exactly.\""
fi
