#!/bin/bash
# Usage: poirot                   # review current worktree
#        poirot /path/to/wt
set -e
source "$HOME/dev-system/bin/_lib.sh"

dir="${1:-$(pwd)}"
cd "$dir"

resolve_named_role "Poirot"

diff=$(git diff main...HEAD)
task=$(cat .agent-task.md 2>/dev/null || echo "(no task file)")
context=$(cat .agent-context.md 2>/dev/null || echo "(no context)")
repo_agents=$(cat AGENTS.md 2>/dev/null || echo "(no repo AGENTS.md)")

prompt="You are operating as $ROLE_NAME — the reviewer. Your job is to make
the human's review faster and sharper, NOT to fix anything yourself.

The FIRST line of REVIEW.md must be exactly:

$ROLE_PORTRAIT_MD

Then a blank line, then the review structure below.

ORIGINAL TASK:
$task

REPO CONVENTIONS (AGENTS.md):
$repo_agents

PERSONAL CONTEXT (skills loaded):
$context

DIFF:
$diff

Write .vscode/ai/REVIEW.md to stdout in this exact structure:

## Summary
One sentence: what was changed.

## Likely correct
Things that look right, briefly. Don't pad this.

## Worth a closer look
Specific lines or files where you'd focus human attention. Be concrete:
'src/auth.ts:42 — the early return skips the audit log call, intentional?'

## Possible issues
Things that look wrong. Be honest about confidence.

## Out of scope changes
Anything touched that wasn't part of the task. Even tiny stuff.

## Questions for the human
Things you can't determine from context alone.

Be terse. No preamble, no encouragement, no 'great work' language. Skip
sections that are empty rather than writing 'none'."

mkdir -p "$dir/.vscode/ai"
cp "$HOME/dev-system/portraits/poirot.png" "$dir/.vscode/ai/" 2>/dev/null || true

printf "\n🎩 \033[1;35mPoirot\033[0m is reviewing \033[1;36m%s\033[0m...\n\n" "$(basename "$dir")"
if echo "$prompt" | claude -p --permission-mode bypassPermissions > "$dir/.vscode/ai/REVIEW.md"; then
  printf "✅ \033[1;32mReview written to\033[0m .vscode/ai/REVIEW.md\n"
else
  printf "❌ \033[1;31mPoirot encountered an error\033[0m\n"
  exit 1
fi
