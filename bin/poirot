#!/bin/bash
# Usage: poirot                        # review current worktree
#        poirot /path/to/wt            # review specific worktree
#        poirot . "focus on auth"      # with extra instructions
#        poirot --compare              # compare Pat vs Mat (reads ~/.mat_last_worktree)
#        poirot --compare "notes"      # compare with extra instructions
set -e
source "$HOME/dev-system/bin/_lib.sh"

compare=0
if [ "$1" = "--compare" ]; then
  compare=1
  shift
fi

dir="${1:-$(pwd)}"
extra_instructions="${2:-}"
cd "$dir"

resolve_named_role "Poirot"

mkdir -p "$dir/.ai-team"
cp "$HOME/dev-system/portraits/poirot.png" "$dir/.ai-team/" 2>/dev/null || true

base=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || echo "main")

if [ "$compare" = "1" ]; then
  mat_dir=$(cat "$HOME/.mat_last_worktree" 2>/dev/null || echo "")
  if [ -z "$mat_dir" ] || [ ! -d "$mat_dir" ]; then
    printf "❌ No Mat worktree found — run mat first\n"
    exit 1
  fi

  diff_pat=$(git diff "$base"...HEAD)
  diff_mat=$(git -C "$mat_dir" diff "$base"...HEAD)
  task=$(cat .agent-task.md 2>/dev/null || echo "(no task file)")
  investigation=$(cat .ai-team/INVESTIGATION.md 2>/dev/null || echo "")
  repo_agents=$(cat AGENTS.md 2>/dev/null || echo "(no repo AGENTS.md)")
  summary_pat=$(cat .ai-team/FIX-SUMMARY.md 2>/dev/null || echo "")
  summary_mat=$(cat "$mat_dir/.ai-team/FIX-SUMMARY.md" 2>/dev/null || echo "")

  prompt="You are operating as $ROLE_NAME — the reviewer. Two workers (Pat using Claude, Mat using Gemini Flash) solved the same task independently. Your job is to compare both solutions and help the human pick the better one.

Base your verdict on the diffs below. Do not comment on code outside these diffs.

The FIRST line of REVIEW.md must be exactly:

$ROLE_PORTRAIT_MD

ORIGINAL TASK:
$task
${investigation:+
INVESTIGATION:
$investigation}
${extra_instructions:+
EXTRA INSTRUCTIONS FROM HUMAN:
$extra_instructions}
REPO CONVENTIONS (AGENTS.md):
$repo_agents

PAT'S SUMMARY:
${summary_pat:-(no summary)}

PAT'S DIFF:
$diff_pat

MAT'S SUMMARY:
${summary_mat:-(no summary)}

MAT'S DIFF:
$diff_mat

Write your review to stdout in this exact structure:

## Verdict
One sentence: which solution to use and why.

## Pat's approach
Brief summary of what Pat did differently.

## Mat's approach
Brief summary of what Mat did differently.

## Key differences
Concrete tradeoffs — correctness, style, test coverage, edge cases.

## Concerns in the chosen solution
Anything worth a closer look before merging.

## Questions for the human
Anything you can't determine from context alone.

Be terse. No preamble. Skip empty sections."

  printf "\n"
  printf "  \033[1;32m🔨 Pat\033[0m                    \033[1;34m🔧 Mat\033[0m\n"
  printf "  \033[1;32m────────────\033[0m  \033[1;37m⚔️  vs  ⚔️\033[0m  \033[1;34m────────────\033[0m\n"
  printf "  \033[0;37mClaude\033[0m                    \033[0;37mGemini Flash\033[0m\n"
  printf "\n🎩 \033[1;35mPoirot\033[0m is deliberating...\n\n"
  if echo "$prompt" | claude -p --permission-mode bypassPermissions > "$dir/.ai-team/REVIEW.md"; then
    printf "✅ \033[1;32mComparison written to\033[0m .ai-team/REVIEW.md\n"
  else
    printf "❌ \033[1;31mPoirot encountered an error\033[0m\n"
    exit 1
  fi
  exit 0
fi

# Standard single-worktree review
diff=$(git diff "$base"...HEAD)
task=$(cat .agent-task.md 2>/dev/null || echo "(no task file)")
context=$(cat .agent-context.md 2>/dev/null || echo "(no context)")
repo_agents=$(cat AGENTS.md 2>/dev/null || echo "(no repo AGENTS.md)")
fix_summary=$(cat .ai-team/FIX-SUMMARY.md 2>/dev/null || echo "")
investigation=$(cat .ai-team/INVESTIGATION.md 2>/dev/null || echo "")

prompt="You are operating as $ROLE_NAME — the reviewer. Your job is to make
the human's review faster and sharper, NOT to fix anything yourself.

Review ONLY the changes in the diff below. Do not comment on code that was
not modified in this branch.

The FIRST line of REVIEW.md must be exactly:

$ROLE_PORTRAIT_MD

Then a blank line, then the review structure below.

DIFF (this is what you are reviewing):
$diff

ORIGINAL TASK:
$task
${fix_summary:+
WORKER SUMMARY (FIX-SUMMARY.md):
$fix_summary}
${investigation:+
INVESTIGATION (INVESTIGATION.md):
$investigation}
${extra_instructions:+
EXTRA INSTRUCTIONS FROM HUMAN:
$extra_instructions}
REPO CONVENTIONS (AGENTS.md):
$repo_agents

PERSONAL CONTEXT (skills loaded):
$context

Write .ai-team/REVIEW.md to stdout in this exact structure:

## Summary
One sentence: what was changed.

## Likely correct
Things that look right, briefly. Don't pad this.

## Worth a closer look
Specific lines or files where you'd focus human attention. Be concrete:
'src/auth.ts:42 — the early return skips the audit log call, intentional?'

## Possible issues
Things that look wrong. Be honest about confidence.

## Out of scope changes
Anything touched that wasn't part of the task. Even tiny stuff.

## Questions for the human
Things you can't determine from context alone.

Be terse. No preamble, no encouragement, no 'great work' language. Skip
sections that are empty rather than writing 'none'."

branch_current=$(git rev-parse --abbrev-ref HEAD)
stat_summary=$(git diff --stat "$base"...HEAD | tail -1)

printf "\n🎩 \033[1;35mPoirot\033[0m is reviewing \033[1;36m%s\033[0m\n" "$(basename "$dir")"
printf "   \033[0;37m%s\033[0m → \033[0;37m%s\033[0m\n" "$branch_current" "$base"
printf "   \033[0;33m%s\033[0m\n\n" "$stat_summary"
if echo "$prompt" | claude -p --permission-mode bypassPermissions > "$dir/.ai-team/REVIEW.md"; then
  printf "✅ \033[1;32mReview written to\033[0m .ai-team/REVIEW.md\n"
else
  printf "❌ \033[1;31mPoirot encountered an error\033[0m\n"
  exit 1
fi
